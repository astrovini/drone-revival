<module name="Product" dll_name="Mykonos.dll"/>

<include file="FVT2_MB\\TRACE.xml"/>

<variable name="$SCRIPT_VERSION" value="V02.06.00"/>

<variable name="$TEST_SEQUENCE"     value="seq_execute"     indexed="true"/>
<variable name="$TEST_SEQUENCE_PRE" value="seq_execute_pre" indexed="true"/>

<sequence name="seq_execute_pre" pass_event="" failed_event="evt_test_failed" abort_event="evt_test_abort">

  <step name="Get test bench software version" mode="NORMAL">
    <call module="Base"    function="print_version"      script_version="$SCRIPT_VERSION"/>
    <call module="Product" function="print_version"/>
    <call module="Product" function="io_board_configure" command="OPEN" value="1"/>
  </step>
  
</sequence>

<sequence name="seq_execute" pass_event="evt_pass" failed_event="evt_test_failed" abort_event="evt_test_abort">

  <step name="Init wifi tester" mode="NORMAL">
    <call module="Product" function="open_wifi_tester" visa_resource="$ANALYSER_VISA_RESOURCE"/>
    <call module="Base"    function="wait_ms"              value="100"/>
  </step>

  <step name="Reset product in Normal mode" mode="NORMAL">
    <call module="Product" function="io_board_configure" command="ALL_OUTPUT_OFF"/>
    <call module="Base"    function="wait_ms"            value="1000"/>
	<if expression="$TEST_BENCH_CONFIG == 0">
	  <call module="Base"    function="set_variable"     variable="$MOTHER_BOARD_CONSUMPTION_COEFFICIENT"       value="0.1"/>
	  <call module="Product" function="set_digital_output" name="SET_A6"/>
	  <call module="Product" function="set_digital_output" name="SET_A5"/>
      <call module="Base"    function="wait_ms" value="100"/>
	</if>
	<call module="Product" function="set_digital_output" name="PWR_5V_DUT_ON"/>
    <call module="Base"    function="wait_ms"            value="500"/>
    <call module="Product" function="set_digital_output" name="12V_DUT_ON"/>
    <call module="Base"    function="wait_ms"            value="8000"/>
	<call module="Product" function="set_digital_output" name="PWR_5V_DUT_OFF"/>
  </step>

  <if expression="$ENABLE_CURRENT_CONSUMPTION_CHECKING == 1">
  <step name="Check Test current consumption" mode="NORMAL">
    <call module="Product" function="test_current_consumption" name="MOTHER_BOARD" 
                                                               min="$USB_BOOT_STATE_CONSUMPTION_MIN"
                                                               max="$USB_BOOT_STATE_CONSUMPTION_MAX"
                                                               coefficient="$MOTHER_BOARD_CONSUMPTION_COEFFICIENT"/>
  </step>
  </if>
   
  <step name="Init Atheros chip" mode="NORMAL">
    <call module="Product" function="init_debug_uart" port="$COM_PORT" baudrate="115200"/>  
    <call module="Product" function="activate_debug_uart"/>
    <!--call module="Base"    function="wait_ms" value="100"/-->
    <call module="Product" function="send_command_debug_uart" command="wifi_testmode.sh"/>
    <call module="Base"    function="wait_ms" value="3000"/>
    <call module="Product" function="chip_atheros_control" command="SET_MAC_ADDRESS" mac_address="$MAC_ADDRESS"/>
    <call module="Base"    function="wait_ms" value="100"/>
  </step>
 
  <if expression="$ENABLE_TRANSMISSION_MODE_CHECKING == 1">

