<module name="Product" dll_name="Mykonos.dll"/>

<include file="FVT3_DRONE\\TRACE.xml"/>

<variable name="$SCRIPT_VERSION" value="V03.15.00"/>

<variable name="$TEST_SEQUENCE"     value="seq_execute"     indexed="true"/>
<variable name="$TEST_SEQUENCE_PRE" value="seq_execute_pre" indexed="true"/>

<sequence name="seq_execute_pre" pass_event="" failed_event="evt_test_failed" abort_event="evt_test_abort">

  <step name="Get test bench software version" mode="NORMAL">
    <call module="Base"    function="print_version"      script_version="$SCRIPT_VERSION"/>
    <call module="Product" function="print_version"/>
    <call module="Product" function="io_board_configure" command="OPEN" value="1"/>
	<if expression="$ENABLE_CHECK_NETWORK_CONNECTION == 1">
    <call module="Product" function="server_is_connected" network_path="$NETWORK_PATH_TO_CHECK"/>
	</if>	
	<call module="Base"    function="get_date"       year="$YEAR" month="$MONTH" day="$DAY"/>
	<call module="Base"    function="get_time"       hour="$HOUR" minute="$MINUTE"/>
  </step>
  
</sequence>

<sequence name="seq_execute" pass_event="evt_pass" failed_event="evt_test_failed" abort_event="evt_test_abort">


  <if expression="$ENABLE_CHECK_DRONE_CONFIG == 1">
  <step name="Check Drone Configuration" mode="CONTINUE">
    <call module="Base"    function="select_image" command="RESET"/>
    <call module="Base"    function="select_image" command="ADD"   value="PRESENCE_USB_CABLE.jpg"/>
    <call module="Base"    function="select_image" command="SHOW"/>
    <call module="Base"    function="select_image" command="GET_SELECTION" timeout_ms="20000"/>
    <call module="Base"    function="select_image" command="HIDE"/>
  </step>
  </if>
  
  <if expression="$ENABLE_TEST_FIRMWARE_FLASHING == 1">

  <step name="Reset product in normal mode" mode="NORMAL">
    <call module="Product" function="io_board_configure" command="ALL_OUTPUT_OFF"/>
    <call module="Base"    function="wait_ms"            value="1000"/>
    <call module="Product" function="set_digital_output" name="12V_DUT_ON"/>
    <call module="Base"    function="wait_ms"            value="6000"/>
  </step>

  <step name="Open USB communication" mode="NORMAL">
	<call module="Product" function="set_digital_output" name="PWR_5V_DUT_ON"/>
    <call module="Product" function="communication_add"    name="USB_0"/>
	<call module="Product" function="communication_open"   name="USB_0" vendor_id="0x19CF" product_id="0x1000" timeout="5000" result="$LOCAL_RESULT"/>
	<if expression="$LOCAL_RESULT != 0">
	<call module="Base"    function="set_variable"       variable="$VERSION_OK" value="0"/>
	</if>	
	<if expression="$LOCAL_RESULT == 0">
    <call module="Product" function="communication_select" name="USB_0"/>
    <call module="Product" function="check_embedded_software_version" major="$EMBEDDED_TEST_SOFTWARE_VERSION_MAJOR" 
                                                                      minor="$EMBEDDED_TEST_SOFTWARE_VERSION_MINOR"  result="$LOCAL_RESULT"/>
	<if expression="$LOCAL_RESULT != 0">
	<call module="Base"    function="set_variable"       variable="$VERSION_OK" value="0"/>
	</if>	
	<if expression="$LOCAL_RESULT == 0">
	<call module="Base"    function="set_variable"       variable="$VERSION_OK" value="1"/>
	</if>	
	</if>	
  </step>

  <if expression="$VERSION_OK == 0">
  <step name="Open uart com port" mode="NORMAL">
    <call module="Product" function="uart_console" command="OPEN_COM_PORT"
                                                   com_port="$DRONE_SERIAL_COM_PORT" 
                                                   baudrate="$DRONE_SERIAL_BAUDRATE"
                                                   overspeed="$DRONE_SERIAL_OVERSPEED"/>
  </step>
  
  <step name="Flash embedded firmware in ROM" mode="NORMAL">
    <call module="Product" function="io_board_configure" command="ALL_OUTPUT_OFF"/>
    <call module="Base"    function="wait_ms"            value="1000"/>
    <call module="Product" function="set_digital_output" name="PWR_5V_DUT_ON"/>
    <call module="Base"    function="wait_ms"            value="500"/>
    <call module="Product" function="set_digital_output" name="12V_DUT_ON"/>
    <call module="Product" function="control_flash_file"  command="INIT"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_VENDOR_ID"                  value="0x451"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_PRODUCT_ID"                 value="0xD00E"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_WRITE_TIMEOUT"              value="5000"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_ENUM_TIMEOUT"               value="10000"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_CODE_ERROR_READING_TIMEOUT" value="5000"/>
    <call module="Product" function="control_flash_file"  command="USB_FIND_DEVICE"/>
    <call module="Product" function="control_flash_file"  command="SET_BIN_FILE_PATH"                  path="$BINARY_USB_BOOTLOADER_PATH"/>
    <call module="Product" function="control_flash_file"  command="USB_UPLOAD_BIN_FILE"/>
    <call module="Product" function="control_flash_file"  command="USB_RELEASE_DEVICE"/>
	<call module="Base"    function="wait_ms"             value="100"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_VENDOR_ID"                  value="0x19CF"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_PRODUCT_ID"                 value="0x1111"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_WRITE_TIMEOUT"              value="5000"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_ENUM_TIMEOUT"               value="10000"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_CODE_ERROR_READING_TIMEOUT" value="5000"/>
    <call module="Product" function="control_flash_file"  command="USB_FIND_DEVICE"/>
    <call module="Product" function="control_flash_file"  command="SET_PLF_FILE_PATH"                  path="$BINARY_TEST_USB_FLASHER_PATH"/>
    <call module="Product" function="control_flash_file"  command="USB_UPLOAD_FLASHER"/>
    <call module="Product" function="control_flash_file"  command="USB_RELEASE_DEVICE"/>
	<call module="Base"    function="wait_ms"             value="2000"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_VENDOR_ID"                  value="0x19CF"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_PRODUCT_ID"                 value="0x1000"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_WRITE_TIMEOUT"              value="5000"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_ENUM_TIMEOUT"               value="10000"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_CODE_ERROR_READING_TIMEOUT" value="5000"/>    
    <call module="Product" function="control_flash_file"  command="USB_FIND_DEVICE"/>
    <call module="Product" function="control_flash_file"  command="SET_PLF_FILE_PATH"                  path="$BINARY_TEST_FIRMWARE_PATH"/>
    <call module="Product" function="control_flash_file"  command="USB_UPLOAD_PLF_FILE" result="$LOCAL_RESULT"/>
    <if expression="$LOCAL_RESULT != 0">
    <call module="Product" function="io_board_configure" command="ALL_OUTPUT_OFF"/>
    <call module="Base"    function="wait_ms"            value="1000"/>
    <call module="Product" function="set_digital_output" name="PWR_5V_DUT_ON"/>
    <call module="Base"    function="wait_ms"            value="500"/>
    <call module="Product" function="set_digital_output" name="12V_DUT_ON"/>
    <call module="Product" function="control_flash_file"  command="INIT"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_VENDOR_ID"                  value="0x451"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_PRODUCT_ID"                 value="0xD00E"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_WRITE_TIMEOUT"              value="5000"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_ENUM_TIMEOUT"               value="10000"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_CODE_ERROR_READING_TIMEOUT" value="5000"/>
    <call module="Product" function="control_flash_file"  command="USB_FIND_DEVICE"/>
    <call module="Product" function="control_flash_file"  command="SET_BIN_FILE_PATH"                  path="$BINARY_USB_BOOTLOADER_PATH"/>
    <call module="Product" function="control_flash_file"  command="USB_UPLOAD_BIN_FILE"/>
    <call module="Product" function="control_flash_file"  command="USB_RELEASE_DEVICE"/>
	<call module="Base"    function="wait_ms"             value="100"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_VENDOR_ID"                  value="0x19CF"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_PRODUCT_ID"                 value="0x1111"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_WRITE_TIMEOUT"              value="5000"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_ENUM_TIMEOUT"               value="10000"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_CODE_ERROR_READING_TIMEOUT" value="5000"/>
    <call module="Product" function="control_flash_file"  command="USB_FIND_DEVICE"/>
    <call module="Product" function="control_flash_file"  command="SET_PLF_FILE_PATH"                  path="$BINARY_TEST_USB_FLASHER_PATH"/>
    <call module="Product" function="control_flash_file"  command="USB_UPLOAD_FLASHER"/>
    <call module="Product" function="control_flash_file"  command="USB_RELEASE_DEVICE"/>
	<call module="Base"    function="wait_ms"             value="2000"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_VENDOR_ID"                  value="0x19CF"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_PRODUCT_ID"                 value="0x1000"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_WRITE_TIMEOUT"              value="5000"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_ENUM_TIMEOUT"               value="10000"/>
    <call module="Product" function="control_flash_file"  command="SET_USB_CODE_ERROR_READING_TIMEOUT" value="5000"/>    
    <call module="Product" function="control_flash_file"  command="USB_FIND_DEVICE"/>
    <call module="Product" function="control_flash_file"  command="SET_PLF_FILE_PATH"                  path="$BINARY_TEST_FIRMWARE_PATH"/>
    <call module="Product" function="control_flash_file"  command="USB_UPLOAD_PLF_FILE"/>
	</if>
	<call module="Base"    function="wait_ms"             value="3000"/>
	</step>
	
	<step name="Close uart Com port" mode="NORMAL">
    <call module="Product" function="uart_console" command="CLOSE_COM_PORT"/>
	</step> 
  </if>
  </if>		
  
  <if expression="$VERSION_OK == 0">
  <step name="Reset product in normal mode" mode="NORMAL">
    <call module="Product" function="io_board_configure" command="ALL_OUTPUT_OFF"/>
    <call module="Base"    function="wait_ms"            value="1000"/>
    <call module="Product" function="set_digital_output" name="12V_DUT_ON"/>
    <call module="Base"    function="wait_ms"            value="6000"/>
  </step>

  <if expression="$ENABLE_CHECK_FIRMWARE_VERSION == 1">
  <step name="Open USB communication" mode="NORMAL">
    <call module="Product" function="communication_add"    name="USB_0"/>
	<call module="Product" function="set_digital_output" name="PWR_5V_DUT_ON"/>
	<call module="Product" function="communication_open"   name="USB_0" vendor_id="0x19CF" product_id="0x1000" timeout="10000"/>
    <call module="Product" function="communication_select" name="USB_0"/>
  </step>

  <step name="Check embedded test software version" mode="NORMAL">
    <call module="Product" function="check_embedded_software_version" major="$EMBEDDED_TEST_SOFTWARE_VERSION_MAJOR" 
                                                                      minor="$EMBEDDED_TEST_SOFTWARE_VERSION_MINOR" result="$LOCAL_RESULT"/>
    <if expression="$LOCAL_RESULT != 0">
	<call module="Product" function="communication_close"  name="USB_0"/>
	<call module="Product" function="set_digital_output" name="PWR_5V_DUT_OFF"/>
    <call module="Base"    function="wait_ms"            value="1000"/>
	<call module="Product" function="set_digital_output" name="PWR_5V_DUT_ON"/>
	<call module="Product" function="communication_open"   name="USB_0" vendor_id="0x19CF" product_id="0x1000" timeout="10000"/>
    <call module="Product" function="communication_select" name="USB_0"/>
    <call module="Product" function="check_embedded_software_version" major="$EMBEDDED_TEST_SOFTWARE_VERSION_MAJOR" 
                                                                      minor="$EMBEDDED_TEST_SOFTWARE_VERSION_MINOR"/>
	</if>
  </step>
  </if>
  </if>

  <if expression="$ENABLE_USB_KEY_CHECKING == 1">
  
  <step name="Connect USB key to Drone" mode="CONTINUE">
	<call module="Product" function="set_digital_output" name="PWR_5V_DUT_OFF"/>
    <call module="Base"    function="select_image" command="RESET"/>
    <call module="Base"    function="select_image" command="ADD"   value="PLUG_USB_KEY.jpg"/>
    <call module="Base"    function="select_image" command="SHOW"/>
    <call module="Base"    function="select_image" command="GET_SELECTION" timeout_ms="180000"/>
    <call module="Base"    function="select_image" command="HIDE"/>
  </step>

  <step name="Open uart com port" mode="NORMAL">
    <call module="Product" function="uart_console" command="OPEN_COM_PORT"
                                                   com_port="$DRONE_SERIAL_COM_PORT" 
                                                   baudrate="$DRONE_SERIAL_BAUDRATE"
                                                   overspeed="$DRONE_SERIAL_OVERSPEED"/>
  </step>
  
  <step name="Usb Key Mass storage test" mode="NORMAL">
    <call module="Product" function="uart_console" command="TEST_KEY_USB_MASS_STORAGE" time_out="15000" result="$LOCAL_RESULT"/>
    <if expression="$LOCAL_RESULT != 0">
    <call module="Product" function="uart_console" command="TEST_KEY_USB_MASS_STORAGE" time_out="15000"/>
	</if>
  </step>

  <step name="Connect Drone USB to PC" mode="CONTINUE">
    <call module="Base"    function="select_image" command="RESET"/>
    <call module="Base"    function="select_image" command="ADD"   value="UNPLUG_USB_KEY.jpg"/>
    <call module="Base"    function="select_image" command="SHOW"/>
    <call module="Base"    function="select_image" command="GET_SELECTION" timeout_ms="180000"/>
    <call module="Base"    function="select_image" command="HIDE"/>
    <call module="Product" function="uart_console" command="TEST_KEY_USB_NO_PRESENCE" time_out="2000"/>
  </step>

  <step name="Close uart Com port" mode="NORMAL">
	<call module="Product" function="uart_console" command="CLOSE_COM_PORT"/>
  </step> 

  <step name="Open USB communication" mode="NORMAL">
    <call module="Product" function="communication_add"    name="USB_0"/>
	<call module="Product" function="set_digital_output" name="PWR_5V_DUT_ON"/>
	<call module="Product" function="communication_open"   name="USB_0" vendor_id="0x19CF" product_id="0x1000" timeout="10000"/>
    <call module="Product" function="communication_select" name="USB_0"/>
  </step>
  
  </if>  
  
  <if expression="$ENABLE_MOTOR_ENABLE_TEST == 1">
  <step name="Select motor supplier" mode="NORMAL">
    <call module="Base"    function="select_image" command="RESET"/>
    <call module="Base"    function="select_image" command="ADD"   value="CONSTAR.jpg"/>
    <call module="Base"    function="select_image" command="ADD"   value="DM1.jpg"/>
    <call module="Base"    function="select_image" command="ADD"   value="DM2.jpg"/>
    <call module="Base"    function="select_image" command="SHOW"/>
    <call module="Base"    function="select_image" command="GET_SELECTION" read_value="$SUPPLIER_REF" timeout_ms="20000"/>
    <call module="Base"    function="select_image" command="HIDE"/>
  </step>

  <step name="Enable motor" mode="NORMAL">
	<call module="Product" function="upload_file" pc_path="BINARY//BLC_v1.31.hex" embedded_path="/tmp/BLC.hex" block_size="4096"/>
    <call module="Product" function="drone_motor_control" command="FLASH_AND_START_MOTOR" number="1" path="/tmp/BLC.hex"/>
    <call module="Product" function="drone_motor_control" command="CHECK_PRESENCE_FIRMWARE"  number="1"/>
    <call module="Product" function="drone_motor_control" command="FLASH_AND_START_MOTOR" number="2" path="/tmp/BLC.hex"/>
    <call module="Product" function="drone_motor_control" command="CHECK_PRESENCE_FIRMWARE"  number="2"/>
    <call module="Product" function="drone_motor_control" command="FLASH_AND_START_MOTOR" number="3" path="/tmp/BLC.hex"/>
    <call module="Product" function="drone_motor_control" command="CHECK_PRESENCE_FIRMWARE"  number="3"/>
    <call module="Product" function="drone_motor_control" command="FLASH_AND_START_MOTOR" number="4" path="/tmp/BLC.hex"/>
    <call module="Product" function="drone_motor_control" command="CHECK_PRESENCE_FIRMWARE"  number="4"/>
    <call module="Product" function="drone_motor_control" command="CHECK_MOTORS_COHERENCE" value="$SUPPLIER_REF"/>
  </step>
  </if>

  <if expression="$ENABLE_BUTTON_CHECKING == 1">
  <step name="Check Reset button" mode="NORMAL">
    <call module="Product" function="check_gpio_state"   number="87" state="0"/>
    <call module="Product" function="check_reset_button"   number="87" timeout="20000" path="PICTURES\\BUTTON_RESET.JPG"/>
  </step>
  </if>
  
  <if expression="$ENABLE_NAV_DATAS_CHECKING == 1">
  <step name="Test Nav board" mode="NORMAL">
    <call module="Product" function="upload_file" pc_path="BINARY//MYKONOS2.hex" embedded_path="/tmp/MYKONOS2.hex" block_size="4096"/>
	<call module="Product" function="drone_nav_board_control" command="FLASH_FIRMWARE" path="/tmp/MYKONOS2.hex"/>
    <call module="Product" function="drone_nav_board_control" command="INIT"/>
	<call module="Product" function="drone_nav_board_control" command="GET_FIRMWARE_VERSION"/>
	<call module="Product" function="drone_nav_board_control" command="GET_PRESSURE_CALIBRATION_DATA"/>
  <if expression="$ENABLE_ANALYSE == 1">
	<call module="Product" function="drone_nav_board_control" command="GET_MAGNETO_SELFTEST_RESULT"/>
  </if>
  <if expression="$ENABLE_ANALYSE == 0">
	<call module="Product" function="drone_nav_board_check_value" command="CHECK_MAGNETO_SELFTEST_RESULT"/>
  </if>
	<call module="Product" function="drone_nav_board_control" command="FLUSH_BUFFER"/>
    <call module="Product" function="drone_nav_board_control" command="START_THREAD"/>
    <call module="Base"    function="wait_ms"                 value="1000"/>
    <call module="Product" function="drone_nav_board_control" command="START_ACQUISITION"/>
  <if expression="$ENABLE_ANALYSE == 1">
    <call module="Base"    function="wait_ms"                 value="100"/>
    <call module="Product" function="drone_nav_board_control" command="GET_ULTRASOUND_VALUE"/>
    <call module="Product" function="drone_nav_board_control" command="GET_AX_VALUE"/>
    <call module="Product" function="drone_nav_board_control" command="GET_AY_VALUE"/>
    <call module="Product" function="drone_nav_board_control" command="GET_AZ_VALUE"/>
    <call module="Product" function="drone_nav_board_control" command="GET_VX_VALUE"/>
    <call module="Product" function="drone_nav_board_control" command="GET_VY_VALUE"/>
    <call module="Product" function="drone_nav_board_control" command="GET_VZ_VALUE"/>
  </if>
  <if expression="$ENABLE_ANALYSE == 0">
    <call module="Base"    function="wait_ms"                 value="100"/>
    <call module="Product" function="drone_nav_board_check_value" command="CHECK_ULTRASOUND_DISTANCE" coefficient="+0.0272" value="+47.00" tolerance="+10.00"/>
    <call module="Product" function="drone_nav_board_check_value" command="CHECK_AX_VALUE" value="+2048" tolerance="+8.00"/>
    <call module="Product" function="drone_nav_board_check_value" command="CHECK_AY_VALUE" value="+2048" tolerance="+8.00"/>
    <call module="Product" function="drone_nav_board_check_value" command="CHECK_AZ_VALUE" value="+3096" tolerance="+8.00"/>
    <call module="Product" function="drone_nav_board_check_value" command="CHECK_VX_VALUE" min="-1000" max="1000"/>
    <call module="Product" function="drone_nav_board_check_value" command="CHECK_VY_VALUE" min="-1000" max="1000"/>
    <call module="Product" function="drone_nav_board_check_value" command="CHECK_VZ_VALUE" min="-1000" max="1000"/>
  </if>
    <call module="Product" function="drone_nav_board_control" command="STOP_THREAD"/>
  </step>
  </if>  
  
  <if expression="$ENABLE_HORIZONTAL_CAMERA_CHECKING == 1">
  <step name="Test horizontal cam" mode="NORMAL">
	<call module="Base"    function="set_variable"       variable="$PATH_A" value="BINARY//"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_A" string2="HorizontalCam_"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_A" string2="$SERIAL_NUMBER"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_A" string2="_"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_A" string2="$MONTH"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_A" string2="$DAY"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_A" string2="$YEAR"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_A" string2="_"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_A" string2="$HOUR"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_A" string2="$MINUTE"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_A" string2=".uyvy"/>
	<call module="Base"    function="set_variable"       variable="$PATH_B" value="BINARY//"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_B" string2="HorizontalCam_"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_B" string2="$SERIAL_NUMBER"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_B" string2="_"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_B" string2="$MONTH"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_B" string2="$DAY"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_B" string2="$YEAR"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_B" string2="_"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_B" string2="$HOUR"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_B" string2="$MINUTE"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_B" string2=".yuv"/>
	<call module="Base"    function="set_variable"       variable="$PATH_C" value="PICTURES//"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_C" string2="HorizontalCam_"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_C" string2="$SERIAL_NUMBER"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_C" string2="_"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_C" string2="$MONTH"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_C" string2="$DAY"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_C" string2="$YEAR"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_C" string2="_"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_C" string2="$HOUR"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_C" string2="$MINUTE"/>
	<call module="Base"    function="concatenate_string" string1="$PATH_C" string2=".bmp"/>
    <call module="Product" function="init_camera"     model="SOC1040" i2c_bus="/dev/i2c-2" resolution="VGA" frame_rate="15"/>
    <call module="Product" function="start_camera"    video_bus="0"  width="1280" height="720"/>
    <call module="Product" function="snapshot_camera" video_bus="0"  yuv_path="/tmp/HorizontalCam.uyvy" number="5"/>
    <call module="Product" function="stop_camera"     video_bus="0"/>
    <call module="Product" function="download_file"   pc_path="$PATH_A" embedded_path="/tmp/HorizontalCam.uyvy" block_size="2048"/>
    <call module="Product" function="convert_camera_picture_yuv422_to_yuv420_a" width="1280" height="720" yuv420_path="$PATH_B" yuv422_path="$PATH_A"/>
